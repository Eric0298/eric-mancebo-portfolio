---
import MobileActionBar from "../components/mobile/MobileActionBar.astro";
import SeoHead from "../components/seo/SeoHead.astro";
import StructuredData from "../components/seo/StructuredData.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import SiteHeader from "../components/layout/SiteHeader.astro";
import type { Language, TranslationDictionary } from "../i18n/config";
import { buildAlternateLanguageLinks, buildPersonJsonLd, buildWebsiteJsonLd } from "../lib/seo";
import "../styles/global.css";

interface Props {
  language: Language;
  translations: TranslationDictionary;
  canonicalPath: string;
  noindex?: boolean;
}

const { language, translations, canonicalPath, noindex = false } = Astro.props;
const siteUrl = Astro.site ?? Astro.url.origin;
const alternates = buildAlternateLanguageLinks(canonicalPath, siteUrl);
const structuredData = [
  buildPersonJsonLd(translations, language, canonicalPath, siteUrl),
  buildWebsiteJsonLd(translations, language, canonicalPath, siteUrl),
];
---

<!doctype html>
<html lang={translations.metadata.htmlLang}>
  <head>
    <SeoHead
      title={translations.metadata.defaultTitle}
      description={translations.metadata.defaultDescription}
      siteName={translations.metadata.siteName}
      language={language}
      canonicalPath={canonicalPath}
      alternates={alternates}
      noindex={noindex}
      ogLocale={translations.metadata.ogLocale}
    />
    <StructuredData data={structuredData} />
  </head>
  <body>
    <script>
      import "../web-components/contact-intent";
      import "../web-components/scroll-reveal";
    </script>
    <a class="skip-link" href="#main-content">{translations.accessibility.skipToContent}</a>
    <portfolio-contact-intent>
      <SiteHeader language={language} translations={translations} currentPath={canonicalPath} />
      <portfolio-motion-root>
        <main id="main-content" class="site-main">
          <slot />
        </main>
      </portfolio-motion-root>
      <SiteFooter translations={translations} />
      <MobileActionBar translations={translations} />
    </portfolio-contact-intent>
  </body>
</html>
