---
import type { TranslationDictionary } from "../../i18n/config";
import { contactAutomationConfig } from "../../lib/contact-automation";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const form = translations.contact.form;
---

<form class="contact-form" data-contact-form="placeholder" aria-describedby="contact-form-note">
  <div class="contact-form__grid">
    <label>
      <span>{form.name}</span>
      <input type="text" name="name" autocomplete="name" placeholder={form.fieldPlaceholder} disabled />
    </label>
    <label>
      <span>{form.email}</span>
      <input type="email" name="email" autocomplete="email" placeholder={form.fieldPlaceholder} disabled />
    </label>
  </div>
  <label class="contact-form__honeypot" aria-hidden="true">
    <span>{form.honeypot}</span>
    <input type="text" name={contactAutomationConfig.honeypotFieldName} tabindex="-1" autocomplete="off" />
  </label>
  <label>
    <span>{form.message}</span>
    <textarea name="message" rows="4" maxlength={contactAutomationConfig.maxMessageLength} placeholder={form.messagePlaceholder} disabled></textarea>
  </label>
  <p id="contact-form-note" class="contact-form__note">{form.note}</p>
  <button type="button" class="button-link button-link--secondary" disabled>{form.pendingButton}</button>
</form>
