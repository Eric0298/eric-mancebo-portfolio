---
import type { TranslationDictionary } from "../../i18n/config";
import { getExternalLinkAttributes } from "../../lib/external-links";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const mobileContactChannels = translations.contact.channels.filter((channel) =>
  ["email", "whatsapp", "linkedin"].includes(channel.channel),
);
---

<aside class="mobile-action-bar" aria-label={translations.contact.mobileActionsLabel}>
  {mobileContactChannels.map((channel) => {
    const isDisabled = channel.isPlaceholder || channel.href === "#contact";

    return isDisabled ? (
      <span class="mobile-action-bar__item mobile-action-bar__item--placeholder" aria-disabled="true">
        {channel.label}
      </span>
    ) : (
      <a
        class="mobile-action-bar__item"
        href={channel.href}
        data-contact-channel={channel.channel}
        data-contact-intent={channel.automationIntent}
        {...getExternalLinkAttributes(channel.href)}
      >
        {channel.label}
      </a>
    );
  })}
</aside>
