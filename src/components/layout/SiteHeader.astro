---
import { siteConfig } from "../../data/site";
import { getPagePath, type Language, type TranslationDictionary } from "../../i18n/config";
import MobileNavigation from "../mobile/MobileNavigation";
import LanguageSwitcher from "../ui/LanguageSwitcher";
import Container from "../ui/Container.astro";

interface Props {
  language: Language;
  translations: TranslationDictionary;
  currentPath: string;
}

const { language, translations, currentPath } = Astro.props;
const headerNavigation = translations.navigation.items.filter((item) => item.mobilePriority);
const contactNavigation = translations.navigation.items.find((item) => item.section === "contact");
const homePath = getPagePath(language, "home");
---

<header class="site-header">
  <Container size="wide" class="site-header__inner">
    <a class="site-header__brand" href={homePath} aria-label={translations.layout.homeLabel}>
      <img
        class="site-header__logo"
        src="/images/logo/Logo-Eric-Mancebo-SinFondo.png"
        alt={siteConfig.personName}
        width="1672"
        height="941"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="site-header__nav" aria-label={translations.navigation.primaryLabel}>
      {headerNavigation.map((item) => (
        <a href={item.href} data-section={item.section}>{item.label}</a>
      ))}
    </nav>

    <div class="site-header__controls">
      <LanguageSwitcher
        currentLanguage={language}
        currentPath={currentPath}
        labels={translations.languageSwitcher}
        client:load
      />
      {contactNavigation ? (
        <a class="site-header__contact" href={contactNavigation.href}>{contactNavigation.label}</a>
      ) : null}
      <MobileNavigation
        navItems={translations.navigation.items}
        contactItems={translations.contact.channels}
        labels={translations.navigation}
        languageLabels={translations.languageSwitcher}
        contactLabel={translations.contact.mobileChannelsLabel}
        currentLanguage={language}
        currentPath={currentPath}
        client:load
      />
    </div>
  </Container>
</header>
