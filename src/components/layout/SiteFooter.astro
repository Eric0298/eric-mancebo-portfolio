---
import { primaryNavigation } from "../../data/navigation";
import { siteConfig } from "../../data/site";
import Container from "../ui/Container.astro";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <Container size="wide" class="site-footer__inner">
    <div>
      <p class="site-footer__name">{siteConfig.personName}</p>
      <p class="site-footer__summary">
        Portfolio architecture prepared for future case studies, automation, chatbot support, and quality evidence.
      </p>
    </div>
    <nav class="site-footer__nav" aria-label="Footer navigation">
      {primaryNavigation.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <p class="site-footer__meta">&copy; {currentYear} {siteConfig.personName}</p>
  </Container>
</footer>
