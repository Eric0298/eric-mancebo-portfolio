---
import type { ContactChannel } from "../../data/schemas";
import { getExternalLinkAttributes } from "../../lib/external-links";

interface Props {
  channel: ContactChannel;
}

const { channel } = Astro.props;
const isDisabled = channel.isPlaceholder || channel.href === "#contact";
const externalAttributes = getExternalLinkAttributes(channel.href);
---

{
  isDisabled ? (
    <article class="contact-card contact-card--placeholder" aria-disabled="true">
      <p class="contact-card__label">{channel.label}</p>
      <h3 class="contact-card__handle">{channel.handle}</h3>
      <p class="contact-card__summary">{channel.summary}</p>
      <p class="contact-card__intent">Intent: {channel.automationIntent}</p>
    </article>
  ) : (
    <a
      class="contact-card"
      href={channel.href}
      data-contact-channel={channel.channel}
      data-contact-intent={channel.automationIntent}
      {...externalAttributes}
    >
      <p class="contact-card__label">{channel.label}</p>
      <h3 class="contact-card__handle">{channel.handle}</h3>
      <p class="contact-card__summary">{channel.summary}</p>
      <p class="contact-card__intent">Intent: {channel.automationIntent}</p>
    </a>
  )
}
