---
import type { Project } from "../../data/schemas";
import { getExternalLinkAttributes } from "../../lib/external-links";
import BadgeList from "../ui/BadgeList.astro";

interface Props {
  project: Project;
  statusLabel: string;
  highlightLabel: string;
  technicalFocusLabel: string;
  stackLabel: string;
}

const { project, statusLabel, highlightLabel, technicalFocusLabel, stackLabel } = Astro.props;
---

<article class:list={["project-card", project.isFlagship && "project-card--flagship"]} data-project={project.slug}>
  <div class="project-card__header">
    <p class="project-card__status">{statusLabel}</p>
    <h3 class="project-card__title">{project.name}</h3>
  </div>
  <p class="project-card__summary">{project.summary}</p>
  <div class="project-card__focus-block">
    <p class="project-card__section-label">{technicalFocusLabel}</p>
    <p class="project-card__focus">{project.technicalFocus}</p>
  </div>
  <div class="project-card__stack">
    <p class="project-card__section-label">{stackLabel}</p>
    <BadgeList items={project.stack} label={`${stackLabel}: ${project.name}`} />
  </div>
  <div class="project-card__highlights">
    <p class="project-card__section-label">{highlightLabel}</p>
    <BadgeList items={project.plannedHighlights} label={`${highlightLabel}: ${project.name}`} />
  </div>
  <p class="project-card__note">{project.note}</p>
  {project.links.length > 0 ? (
    <div class="project-card__links">
      {project.links.map((link) => (
        <a href={link.href} {...getExternalLinkAttributes(link.href)}>
          {link.label}
        </a>
      ))}
    </div>
  ) : (
    <span class="project-card__cta" data-state="placeholder">{project.ctaLabel}</span>
  )}
</article>
