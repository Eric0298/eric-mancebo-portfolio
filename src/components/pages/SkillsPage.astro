---
import { getPagePath, type Language } from "../../i18n/config";
import { useTranslations } from "../../i18n/useTranslations";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SkillsCapabilityMapSection from "../sections/SkillsCapabilityMapSection.astro";
import SkillsCategoryMapSection from "../sections/SkillsCategoryMapSection.astro";
import SkillsEvidenceSection from "../sections/SkillsEvidenceSection.astro";
import SkillsFinalCtaSection from "../sections/SkillsFinalCtaSection.astro";
import SkillsNotebookHero from "../sections/SkillsNotebookHero.astro";
import SkillsPositioningSection from "../sections/SkillsPositioningSection.astro";
import SkillsProcessDeviceSection from "../sections/SkillsProcessDeviceSection.astro";
import "../../styles/skills.css";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const translations = useTranslations(language);
const canonicalPath = getPagePath(language, "skills");
const page = translations.pages.skills;
---

<BaseLayout
  language={language}
  translations={translations}
  canonicalPath={canonicalPath}
  title={page.metaTitle}
  description={page.metaDescription}
>
  <div class="skills-notebook-page">
    <SkillsNotebookHero language={language} translations={translations} />
    <SkillsPositioningSection translations={translations} />
    <SkillsCapabilityMapSection translations={translations} />
    <SkillsCategoryMapSection translations={translations} />
    <SkillsProcessDeviceSection translations={translations} />
    <SkillsEvidenceSection translations={translations} />
    <SkillsFinalCtaSection language={language} translations={translations} />
  </div>
</BaseLayout>
