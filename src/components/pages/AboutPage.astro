---
import { getPagePath, type Language } from "../../i18n/config";
import { useTranslations } from "../../i18n/useTranslations";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutCTA from "../about/AboutCTA.astro";
import AboutClosing from "../about/AboutClosing.astro";
import AboutHero from "../about/AboutHero.astro";
import AboutHorizontalStory from "../about/AboutHorizontalStory.astro";
import AboutManifesto from "../about/AboutManifesto.astro";
import AboutOriginCollage from "../about/AboutOriginCollage.astro";
import AboutTimeline from "../about/AboutTimeline.astro";
import "../../styles/about.css";
import "../../styles/about-scroll.css";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const translations = useTranslations(language);
const canonicalPath = getPagePath(language, "about");
const page = translations.pages.about;
---

<BaseLayout
  language={language}
  translations={translations}
  canonicalPath={canonicalPath}
  title={page.metaTitle}
  description={page.metaDescription}
>
  <div class="about-journey-page">
    <AboutHero translations={translations} />
    <AboutManifesto translations={translations} />
    <AboutOriginCollage translations={translations} />
    <AboutHorizontalStory translations={translations} />
    <AboutTimeline translations={translations} />
    <AboutClosing translations={translations} />
    <AboutCTA language={language} translations={translations} />
  </div>
</BaseLayout>
