---
import { getPagePath, type Language } from "../../i18n/config";
import { useTranslations } from "../../i18n/useTranslations";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutSection from "../sections/AboutSection.astro";
import CvSection from "../sections/CvSection.astro";
import PageHero from "../sections/PageHero.astro";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const translations = useTranslations(language);
const canonicalPath = getPagePath(language, "about");
const page = translations.pages.about;
---

<BaseLayout
  language={language}
  translations={translations}
  canonicalPath={canonicalPath}
  title={page.metaTitle}
  description={page.metaDescription}
>
  <PageHero page={page} pageKey="about" />
  <AboutSection translations={translations} />
  <CvSection translations={translations} />
</BaseLayout>
