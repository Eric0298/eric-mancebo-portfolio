---
import { getPagePath, type Language } from "../../i18n/config";
import { useTranslations } from "../../i18n/useTranslations";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../sections/PageHero.astro";
import ProjectShowcaseSection from "../sections/ProjectShowcaseSection.astro";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const translations = useTranslations(language);
const canonicalPath = getPagePath(language, "projects");
const page = translations.pages.projects;
---

<BaseLayout
  language={language}
  translations={translations}
  canonicalPath={canonicalPath}
  title={page.metaTitle}
  description={page.metaDescription}
>
  <PageHero page={page} pageKey="projects" />
  <ProjectShowcaseSection translations={translations} />
</BaseLayout>
