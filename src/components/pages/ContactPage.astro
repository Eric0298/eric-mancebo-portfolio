---
import { getPagePath, type Language } from "../../i18n/config";
import { useTranslations } from "../../i18n/useTranslations";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactMethods from "../contact/ContactMethods.astro";
import ContactForm from "../forms/ContactForm.astro";
import "../../styles/contact.css";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const translations = useTranslations(language);
const canonicalPath = getPagePath(language, "contact");
const page = translations.pages.contact;
const contactPage = translations.contactPage;
---

<BaseLayout
  language={language}
  translations={translations}
  canonicalPath={canonicalPath}
  title={page.metaTitle}
  description={page.metaDescription}
>
  <section class="contact-page" aria-labelledby="contact-page-title">
    <div class="contact-page__layout">
      <div class="contact-page__intro">
        <h1 id="contact-page-title">{contactPage.title}</h1>
        <p>{contactPage.subtitle}</p>
      </div>

      <ContactMethods translations={translations} />
      <ContactForm translations={translations} />
    </div>
  </section>
</BaseLayout>
