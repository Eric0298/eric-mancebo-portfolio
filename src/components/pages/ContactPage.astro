---
import { getPagePath, type Language } from "../../i18n/config";
import { useTranslations } from "../../i18n/useTranslations";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactNotebookSection from "../sections/ContactNotebookSection.astro";
import PageHero from "../sections/PageHero.astro";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const translations = useTranslations(language);
const canonicalPath = getPagePath(language, "contact");
const page = translations.pages.contact;
---

<BaseLayout
  language={language}
  translations={translations}
  canonicalPath={canonicalPath}
  title={page.metaTitle}
  description={page.metaDescription}
>
  <PageHero page={page} pageKey="contact" />
  <ContactNotebookSection translations={translations} />
</BaseLayout>
