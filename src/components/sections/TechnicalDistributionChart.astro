---
import type { TranslationDictionary } from "../../i18n/config";

interface Props {
  chart: TranslationDictionary["skillsPage"]["technicalDistributionChart"];
}

const { chart } = Astro.props;
const colors = [
  "hsl(206 72% 62%)",
  "hsl(259 58% 68%)",
  "hsl(49 92% 67%)",
  "hsl(156 48% 60%)",
  "hsl(10 88% 72%)",
  "hsl(328 52% 70%)",
];

const chartSize = 240;
const chartCenter = chartSize / 2;
const arcRadius = 88;
const labelRadius = 88;
const strokeWidth = 58;
const startAngle = -90;

const polarToCartesian = (radius: number, angleInDegrees: number) => {
  const angleInRadians = (angleInDegrees * Math.PI) / 180;

  return {
    x: chartCenter + radius * Math.cos(angleInRadians),
    y: chartCenter + radius * Math.sin(angleInRadians),
  };
};

const describeArc = (startAngleInDegrees: number, endAngleInDegrees: number) => {
  const start = polarToCartesian(arcRadius, startAngleInDegrees);
  const end = polarToCartesian(arcRadius, endAngleInDegrees);
  const largeArcFlag = endAngleInDegrees - startAngleInDegrees <= 180 ? "0" : "1";

  return `M ${start.x.toFixed(3)} ${start.y.toFixed(3)} A ${arcRadius} ${arcRadius} 0 ${largeArcFlag} 1 ${end.x.toFixed(3)} ${end.y.toFixed(3)}`;
};

let cursor = 0;
const segments = chart.items.map((item, index) => {
  const sweep = item.percent * 3.6;
  const start = startAngle + cursor;
  const end = start + sweep;
  const middle = start + sweep / 2;
  const labelPoint = polarToCartesian(labelRadius, middle);
  cursor += sweep;

  return {
    ...item,
    color: colors[index % colors.length],
    path: describeArc(start, end),
    labelX: labelPoint.x,
    labelY: labelPoint.y,
    labelRotation: Math.max(Math.min(middle * 0.08, 8), -8),
    start,
    end,
  };
});
---

<div
  class="technical-distribution-chart"
  aria-label={chart.ariaLabel}
  data-motion="reveal"
>
  <div class="technical-distribution-chart__intro">
    <p>{chart.eyebrow}</p>
    <h3>{chart.title}</h3>
    <span>{chart.summary}</span>
  </div>

  <div class="technical-distribution-chart__body">
    <div class="technical-distribution-chart__visual" aria-hidden="true">
      <div class="technical-distribution-chart__ring">
        <svg
          class="technical-distribution-chart__svg"
          viewBox={`0 0 ${chartSize} ${chartSize}`}
          role="presentation"
          style={`--distribution-stroke-width: ${strokeWidth}px`}
        >
          <circle
            class="technical-distribution-chart__track"
            cx={chartCenter}
            cy={chartCenter}
            r={arcRadius}
            fill="none"
          />

          {segments.map((segment) => (
            <g class="technical-distribution-chart__segment">
              <path
                class="technical-distribution-chart__arc"
                d={segment.path}
                fill="none"
                stroke={segment.color}
                pathLength={100}
              />
              <text
                class="technical-distribution-chart__segment-percent"
                x={segment.labelX}
                y={segment.labelY}
                transform={`rotate(${segment.labelRotation.toFixed(2)} ${segment.labelX.toFixed(3)} ${segment.labelY.toFixed(3)})`}
              >
                {segment.percent}%
              </text>
            </g>
          ))}
        </svg>

        <div class="technical-distribution-chart__center">
          <strong>{chart.centerValue}</strong>
          <span>{chart.centerLabel}</span>
        </div>
      </div>
    </div>

    <ol class="technical-distribution-chart__legend">
      {segments.map((segment) => (
        <li style={`--segment-color: ${segment.color}`}>
          <span aria-hidden="true"></span>
          <div>
            <strong>{segment.label}</strong>
            <small>{segment.note}</small>
          </div>
          <b>{segment.percent}%</b>
        </li>
      ))}
    </ol>
  </div>
</div>
