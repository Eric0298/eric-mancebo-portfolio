---
import type { TranslationDictionary } from "../../i18n/config";
import SectionShell from "../ui/SectionShell.astro";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const section = translations.sections.automation;
---

<SectionShell id={section.anchor} eyebrow={section.eyebrow} title={section.title} summary={section.summary}>
  <ol class="flow-list">
    {translations.automation.steps.map((step, index) => (
      <li class="flow-list__item">
        <span class="flow-list__index">{String(index + 1).padStart(2, "0")}</span>
        <div>
          <h3>{step.title}</h3>
          <p>{step.summary}</p>
          <small>{step.futureCapability}</small>
        </div>
      </li>
    ))}
  </ol>
</SectionShell>
