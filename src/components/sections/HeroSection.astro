---
import { siteConfig } from "../../data/site";
import type { TranslationDictionary } from "../../i18n/config";
import MotionWrapper from "../effects/MotionWrapper.astro";
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const section = translations.sections.hero;
---

<section id={section.anchor} class="hero-section" aria-labelledby="hero-title">
  <Container size="wide" class="hero-section__inner">
    <div class="hero-section__content" data-motion="reveal">
      <p class="hero-section__eyebrow">{section.eyebrow}</p>
      <h1 id="hero-title">{siteConfig.personName}</h1>
      <p class="hero-section__summary">{section.summary}</p>
      <div class="hero-section__actions">
        <ButtonLink href="#projects">{translations.hero.actions.projects}</ButtonLink>
        <ButtonLink href="#contact" variant="secondary">{translations.hero.actions.contact}</ButtonLink>
      </div>
    </div>

    <MotionWrapper mode="subtle" class="hero-section__snapshot">
      <p class="hero-section__snapshot-label">{translations.hero.snapshotLabel}</p>
      <ul>
        {translations.hero.architectureSignals.map((signal) => <li>{signal}</li>)}
      </ul>
    </MotionWrapper>
  </Container>
</section>
