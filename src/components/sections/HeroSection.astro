---
import { siteConfig } from "../../data/site";
import { getPagePath, type Language, type TranslationDictionary } from "../../i18n/config";
import MotionWrapper from "../effects/MotionWrapper.astro";
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";

interface Props {
  language: Language;
  translations: TranslationDictionary;
}

const { language, translations } = Astro.props;
const section = translations.sections.hero;
const headlineAnnotation = translations.hero.annotations.find((annotation) => annotation.placement === "headline");
const portraitAnnotation = translations.hero.annotations.find((annotation) => annotation.placement === "portrait");
const actionsAnnotation = translations.hero.annotations.find((annotation) => annotation.placement === "actions");
const projectsPath = getPagePath(language, "projects");
const contactPath = getPagePath(language, "contact");
---

<section id={section.anchor} class="hero-section" aria-labelledby="hero-title">
  <Container size="wide" class="hero-section__inner">
    <div class="hero-section__editorial" data-motion="reveal">
      <p class="hero-section__eyebrow">{section.eyebrow}</p>
      <h1 id="hero-title" class="hero-section__title" aria-label={`${siteConfig.personName}: ${translations.hero.displayLines.join(" ")}`}>
        <span class="hero-section__name">{siteConfig.personName}</span>
        {translations.hero.displayLines.map((line, index) => (
          <span class:list={["hero-section__title-line", index === 1 && "hero-section__title-line--offset"]}>
            {line}
          </span>
        ))}
      </h1>
      {headlineAnnotation ? (
        <p class="hero-annotation hero-annotation--headline">{headlineAnnotation.label}</p>
      ) : null}
    </div>

    <MotionWrapper mode="subtle" class="hero-section__portrait-layer">
      <div class="hero-portrait" aria-label={translations.hero.portrait.alt} data-portrait-status="placeholder">
        <span class="hero-portrait__label">{translations.hero.portrait.placeholderLabel}</span>
        <span class="hero-portrait__figure">{translations.hero.portrait.futureImageLabel}</span>
        <span class="hero-portrait__note">{translations.hero.portrait.placeholderNote}</span>
      </div>
      {portraitAnnotation ? (
        <p class="hero-annotation hero-annotation--portrait">{portraitAnnotation.label}</p>
      ) : null}
    </MotionWrapper>

    <div class="hero-section__lower" data-motion="reveal">
      <p class="hero-section__summary">{translations.hero.supportingParagraph}</p>
      <div class="hero-section__actions" data-contact-ready="future-intake">
        <ButtonLink href={projectsPath}>{translations.hero.actions.projects}</ButtonLink>
        <ButtonLink href={contactPath} variant="secondary">{translations.hero.actions.contact}</ButtonLink>
      </div>
      {actionsAnnotation ? (
        <p class="hero-annotation hero-annotation--actions">{actionsAnnotation.label}</p>
      ) : null}
    </div>

    <div class="hero-section__chips" aria-label={translations.hero.snapshotLabel}>
      {translations.hero.architectureSignals.map((signal, index) => (
        <span class:list={["hero-chip", `hero-chip--${(index % 4) + 1}`]}>{signal}</span>
      ))}
    </div>

    <div class="hero-section__stickers" aria-hidden="true">
      {translations.hero.stickers.map((sticker, index) => (
        <span class:list={["hero-sticker", `hero-sticker--${index + 1}`]}>{sticker}</span>
      ))}
    </div>
  </Container>
</section>
