---
import { siteConfig } from "../../data/site";
import { getPagePath, type Language, type TranslationDictionary } from "../../i18n/config";
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";

interface Props {
  language: Language;
  translations: TranslationDictionary;
}

const { language, translations } = Astro.props;
const section = translations.sections.hero;
const titleLines = translations.hero.displayLines.slice(0, 2);
const titleDepths = [0.18, -0.12];
const projectsPath = getPagePath(language, "projects");
const contactPath = getPagePath(language, "contact");
---

<section id={section.anchor} class="hero-section" aria-labelledby="hero-title" data-home-hero>
  <Container size="wide" class="hero-section__inner">
    <div class="hero-section__stage">
      <p class="hero-section__intro" data-hero-depth style="--hero-depth: 0.08">{section.eyebrow}</p>

      <h1 id="hero-title" class="hero-section__title" aria-label={`${siteConfig.personName}: ${translations.hero.displayLines.join(" ")}`}>
        {titleLines.map((line, index) => (
          <span
            class:list={[
              "hero-section__title-line",
              index === 0 ? "hero-section__title-line--solid" : "hero-section__title-line--outline",
            ]}
            data-hero-depth
            style={`--hero-depth: ${titleDepths[index]}`}
          >
            {line}
          </span>
        ))}
      </h1>

      <div class="hero-section__portrait-anchor" aria-hidden="true">
        <div class="hero-section__portrait-layer" data-hero-depth style="--hero-depth: 0.42">
          <img
            class="hero-section__portrait"
            src="/images/ImagenHeroPortfolioBlancoYNegroSinFondo.png"
            alt=""
            width="1122"
            height="1402"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>

      <p class="sr-only">{translations.hero.portrait.alt}</p>

      <div class="hero-section__meta" aria-label={translations.hero.snapshotLabel}>
        <p class="hero-section__summary" data-hero-depth style="--hero-depth: -0.06">
          {translations.hero.supportingParagraph}
        </p>
        <ul class="hero-section__marks">
          {translations.hero.architectureSignals.map((signal) => (
            <li>{signal}</li>
          ))}
        </ul>
      </div>

      <div class="hero-section__actions" data-contact-ready="future-intake" data-hero-depth style="--hero-depth: 0.16">
        <ButtonLink href={projectsPath}>{translations.hero.actions.projects}</ButtonLink>
        <ButtonLink href={contactPath} variant="secondary">{translations.hero.actions.contact}</ButtonLink>
      </div>
    </div>
  </Container>
</section>

<script>
  (() => {
    const hero = document.querySelector<HTMLElement>("[data-home-hero]");
    const finePointer = window.matchMedia("(pointer: fine)");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (!hero || !finePointer.matches || reducedMotion.matches) return;

    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let frame = 0;

    const render = () => {
      currentX += (targetX - currentX) * 0.12;
      currentY += (targetY - currentY) * 0.12;
      hero.style.setProperty("--hero-parallax-x", `${currentX.toFixed(2)}px`);
      hero.style.setProperty("--hero-parallax-y", `${currentY.toFixed(2)}px`);
      frame = window.requestAnimationFrame(render);
    };

    const handlePointerMove = (event: PointerEvent) => {
      const rect = hero.getBoundingClientRect();
      const normalizedX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      const normalizedY = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
      targetX = normalizedX * 24;
      targetY = normalizedY * 16;
    };

    const settle = () => {
      targetX = 0;
      targetY = 0;
    };

    const disable = () => {
      window.cancelAnimationFrame(frame);
      hero.style.removeProperty("--hero-parallax-x");
      hero.style.removeProperty("--hero-parallax-y");
      hero.removeEventListener("pointermove", handlePointerMove);
      hero.removeEventListener("pointerleave", settle);
    };

    hero.addEventListener("pointermove", handlePointerMove, { passive: true });
    hero.addEventListener("pointerleave", settle, { passive: true });
    finePointer.addEventListener("change", () => {
      if (!finePointer.matches) disable();
    });
    reducedMotion.addEventListener("change", () => {
      if (reducedMotion.matches) disable();
    });

    frame = window.requestAnimationFrame(render);
  })();
</script>
