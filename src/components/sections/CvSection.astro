---
import type { TranslationDictionary } from "../../i18n/config";
import SectionShell from "../ui/SectionShell.astro";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const section = translations.sections.cv;
---

<SectionShell id={section.anchor} eyebrow={section.eyebrow} title={section.title} summary={section.summary} density="compact">
  <ol class="cv-timeline">
    {translations.cv.milestones.map((milestone) => (
      <li class="cv-timeline__item">
        <p>{milestone.label}</p>
        <h3>{milestone.title}</h3>
        <span>{milestone.summary}</span>
      </li>
    ))}
  </ol>
</SectionShell>
