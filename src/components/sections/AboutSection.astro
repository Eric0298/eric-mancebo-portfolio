---
import type { TranslationDictionary } from "../../i18n/config";
import PlaceholderCard from "../ui/PlaceholderCard.astro";
import SectionShell from "../ui/SectionShell.astro";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const section = translations.sections.about;
---

<SectionShell id={section.anchor} eyebrow={section.eyebrow} title={section.title} summary={section.summary}>
  <div class="responsive-grid responsive-grid--three">
    {translations.aboutCards.map((card) => (
      <PlaceholderCard label={card.label} title={card.title} summary={card.summary} />
    ))}
  </div>
</SectionShell>
