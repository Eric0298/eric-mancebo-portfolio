---
type FloatingLayer = "left" | "right";

interface FloatingPlaceholder {
  label: string;
  note: string;
  column: FloatingLayer;
  imageSrc: string;
  imageAlt: string;
  imagePosition?: string;
  width?: number;
  height?: number;
}

interface Props {
  items: FloatingPlaceholder[];
}

const { items } = Astro.props;
const collageItems = items.slice(0, 6);
---

<div class="about-floating-placeholders" aria-hidden="true">
  {collageItems.map((item, index) => (
    <figure class:list={["about-floating-card", `about-floating-card--${item.column}`, `about-floating-card--slot-${index + 1}`]}>
      <div class="about-floating-card__media">
        <img
          src={item.imageSrc}
          alt={item.imageAlt}
          width={item.width}
          height={item.height}
          loading="lazy"
          decoding="async"
          style={item.imagePosition ? `object-position: ${item.imagePosition}` : undefined}
        />
      </div>
      <figcaption>
        <span>{item.label}</span>
        <small>{item.note}</small>
      </figcaption>
    </figure>
  ))}
</div>
