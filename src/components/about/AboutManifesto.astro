---
import type { TranslationDictionary } from "../../i18n/config";

interface Props {
  translations: TranslationDictionary;
}

const { translations } = Astro.props;
const manifesto = translations.aboutPage.manifesto;
const fourPhotoPositions = [1, 2, 4, 5];
const visibleMedia = manifesto.media.map((item, index) => ({
  item,
  position: manifesto.media.length === 4 ? (fourPhotoPositions[index] ?? index + 1) : index + 1,
}));
---

<section id="about-manifesto" class="about-manifesto" aria-label={manifesto.phrase}>
  <div class="about-manifesto__scene">
    <div class="about-manifesto__media-stack" aria-hidden="true">
      {visibleMedia.map(({ item, position }) => (
        <figure
          class:list={["about-manifesto__photo", `about-manifesto__photo--${position}`]}
          style={`--manifesto-image-position: ${item.imagePosition ?? "center"};`}
        >
          <img
            src={item.imageSrc}
            alt=""
            width={item.width}
            height={item.height}
            loading="lazy"
            decoding="async"
            sizes="(min-width: 900px) 32vw, 46vw"
          />
        </figure>
      ))}
    </div>

    <div class="about-manifesto__copy">
      <h2 data-motion="reveal">{manifesto.phrase}</h2>
      <p class="about-manifesto__support">{manifesto.support}</p>
    </div>
  </div>
</section>
