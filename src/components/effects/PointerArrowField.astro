---
interface Props {
  count?: number;
  columns?: number;
  class?: string;
}

const { count = 42, columns = 7, class: className = "" } = Astro.props;
const arrowCount = Math.max(1, Math.min(count, 120));
const arrows = Array.from({ length: arrowCount });
---

<pointer-arrow-field
  class:list={["pointer-arrow-field", className]}
  style={`--arrow-columns: ${columns};`}
  aria-hidden="true"
>
  {arrows.map((_, index) => <span class="pointer-arrow-field__arrow" style={`--arrow-index: ${index};`}></span>)}
</pointer-arrow-field>

<script>
  class PointerArrowField extends HTMLElement {
    connectedCallback() {
      this.arrows = Array.from(this.querySelectorAll(".pointer-arrow-field__arrow"));
      PointerArrowField.instances.add(this);
      PointerArrowField.ensureListeners();
      PointerArrowField.requestUpdate();
    }

    disconnectedCallback() {
      PointerArrowField.instances.delete(this);
    }

    updateToPointer(pointer) {
      const fieldRect = this.getBoundingClientRect();

      if (
        fieldRect.width <= 0 ||
        fieldRect.height <= 0 ||
        fieldRect.bottom < 0 ||
        fieldRect.right < 0 ||
        fieldRect.top > window.innerHeight ||
        fieldRect.left > window.innerWidth
      ) {
        return;
      }

      const targetX = pointer?.x ?? fieldRect.left + fieldRect.width / 2;
      const targetY = pointer?.y ?? fieldRect.top + fieldRect.height / 2;

      for (const arrow of this.arrows) {
        const arrowRect = arrow.getBoundingClientRect();
        const arrowX = arrowRect.left + arrowRect.width / 2;
        const arrowY = arrowRect.top + arrowRect.height / 2;
        const angle = Math.atan2(targetY - arrowY, targetX - arrowX) * (180 / Math.PI);

        arrow.style.setProperty("--pointer-angle", `${angle}deg`);
      }
    }

    static ensureListeners() {
      if (PointerArrowField.hasListeners) {
        return;
      }

      PointerArrowField.hasListeners = true;

      window.addEventListener(
        "pointermove",
        (event) => {
          PointerArrowField.pointer = {
            x: event.clientX,
            y: event.clientY,
          };
          PointerArrowField.requestUpdate();
        },
        { passive: true },
      );

      window.addEventListener(
        "pointerdown",
        (event) => {
          PointerArrowField.pointer = {
            x: event.clientX,
            y: event.clientY,
          };
          PointerArrowField.requestUpdate();
        },
        { passive: true },
      );

      window.addEventListener("resize", () => PointerArrowField.requestUpdate(), { passive: true });
    }

    static requestUpdate() {
      if (PointerArrowField.frame) {
        return;
      }

      PointerArrowField.frame = window.requestAnimationFrame(() => {
        PointerArrowField.frame = 0;

        for (const field of PointerArrowField.instances) {
          field.updateToPointer(PointerArrowField.pointer);
        }
      });
    }
  }

  PointerArrowField.instances = new Set();
  PointerArrowField.pointer = null;
  PointerArrowField.frame = 0;
  PointerArrowField.hasListeners = false;

  if (!customElements.get("pointer-arrow-field")) {
    customElements.define("pointer-arrow-field", PointerArrowField);
  }
</script>

<style>
  .pointer-arrow-field {
    --arrow-size: clamp(0.82rem, 2.3vw, 2.05rem);
    position: absolute;
    inset: 0;
    z-index: 0;
    display: grid;
    grid-template-columns: repeat(var(--arrow-columns, 7), minmax(0, 1fr));
    grid-auto-rows: 1fr;
    align-items: center;
    justify-items: center;
    overflow: hidden;
    color: hsl(0 0% 100% / 0.86);
    opacity: 0.9;
    pointer-events: none;
  }

  .pointer-arrow-field--section {
    --arrow-size: clamp(1.2rem, 3.2vw, 3.2rem);
    inset: var(--space-8) clamp(1rem, 7vw, 6rem);
    opacity: 0.54;
  }

  .pointer-arrow-field__arrow {
    position: relative;
    inline-size: var(--arrow-size);
    aspect-ratio: 2.45 / 1;
    opacity: 0.88;
    transform: rotate(var(--pointer-angle, 0deg));
    transform-origin: 50% 50%;
    transition: transform 95ms linear;
    will-change: transform;
  }

  .pointer-arrow-field__arrow::before {
    content: "";
    position: absolute;
    inset: 0;
    background: currentColor;
    clip-path: polygon(0 34%, 62% 34%, 62% 8%, 100% 50%, 62% 92%, 62% 66%, 0 66%);
    filter: drop-shadow(0.06rem 0.08rem 0 hsl(0 0% 4% / 0.08));
    transform-origin: 50% 50%;
    animation: pointer-arrow-shape 7.2s steps(1, end) infinite;
    animation-delay: calc(var(--arrow-index) * -42ms);
  }

  @keyframes pointer-arrow-shape {
    0%,
    32% {
      opacity: 0.9;
      clip-path: polygon(0 34%, 62% 34%, 62% 8%, 100% 50%, 62% 92%, 62% 66%, 0 66%);
      filter: drop-shadow(0.06rem 0.08rem 0 hsl(0 0% 4% / 0.08));
      transform: scale(1);
    }

    33%,
    65% {
      opacity: 0.66;
      clip-path: polygon(0 42%, 56% 42%, 56% 18%, 100% 50%, 56% 82%, 56% 58%, 0 58%);
      filter:
        drop-shadow(0 0 0.08rem hsl(0 0% 100% / 0.34))
        drop-shadow(0.04rem 0.05rem 0 hsl(0 0% 4% / 0.06));
      transform: scale(0.92);
    }

    66%,
    100% {
      opacity: 0.96;
      clip-path: polygon(0 22%, 52% 22%, 52% 0, 100% 50%, 52% 100%, 52% 78%, 0 78%);
      filter:
        drop-shadow(0 0 0.12rem hsl(0 0% 100% / 0.52))
        drop-shadow(0.08rem 0.1rem 0 hsl(0 0% 4% / 0.08));
      transform: scale(1.04);
    }
  }

  @media (max-width: 767px) {
    .pointer-arrow-field {
      --arrow-size: clamp(0.72rem, 5.2vw, 1.28rem);
    }

    .pointer-arrow-field--section {
      --arrow-size: clamp(1rem, 7vw, 1.8rem);
      inset-inline: var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pointer-arrow-field__arrow {
      transition: none;
    }

    .pointer-arrow-field__arrow::before {
      animation: none;
    }
  }
</style>
